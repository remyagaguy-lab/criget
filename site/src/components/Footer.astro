---
const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/images/logo.png" alt="CRIGET-CS Logo" class="footer-logo" />
        <p class="footer-desc">Votre partenaire fiable pour le développement durable en Afrique.</p>
      </div>
      
      <div class="footer-contact">
        <h2 class="footer-title">Nous contacter</h2>
        <address class="contact-info">
          <p>Lomé, Togo</p>
          <p><a href="mailto:contact@criget-cs.com">contact@criget-cs.com</a></p>
        </address>
      </div>

      <div class="footer-links">
        <h2 class="footer-title">Informations</h2>
        <ul>
          <li><a href="/fr/mentions-legales">Mentions légales</a></li>
          <li><a href="/fr/politique-confidentialite">Politique de confidentialité</a></li>
          <li><a href="/fr/a-propos">À propos</a></li>
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {currentYear} CRIGET-CS. Tous droits réservés.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-neutral-charcoal);
    color: var(--color-neutral-light);
    padding: var(--spacing-8) 0 var(--spacing-4) 0;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-4);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--spacing-6);
    margin-bottom: var(--spacing-8);
  }
  .footer-logo {
    height: 40px;
    margin-bottom: var(--spacing-4);
    filter: brightness(0) invert(1);
  }
  .footer-desc {
    color: var(--color-neutral-gray);
    max-width: 300px;
  }
  .footer-title {
    color: var(--color-neutral-white);
    font-size: 1.1rem;
    margin-bottom: var(--spacing-4);
    font-family: var(--font-family-heading);
  }
  .contact-info {
    font-style: normal;
    color: var(--color-neutral-gray);
  }
  .contact-info a {
    color: var(--color-neutral-light);
    text-decoration: underline;
  }
  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-links li {
    margin-bottom: var(--spacing-2);
  }
  .footer-links a {
    color: var(--color-neutral-gray);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover, .footer-links a:focus {
    color: var(--color-neutral-white);
    text-decoration: underline;
  }
  .footer-bottom {
    border-top: 1px solid var(--color-neutral-charcoal-light);
    padding-top: var(--spacing-4);
    text-align: center;
    color: var(--color-neutral-gray);
    font-size: 0.875rem;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-6);
    }
  }
</style>
